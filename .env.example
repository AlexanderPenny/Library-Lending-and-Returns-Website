# ──────────────────────────────────────
# ─────────────────────────────────────────────────────────────
#  Copy to .env and edit.   cp .env.example .env
#  Generate the two secrets with:
#     npm run gen-secret       -> SESSION_SECRET
#     npm run set-password     -> ADMIN_PASSWORD_HASH
# ─────────────────────────────────────────────────────────────

# --- Server ---
# Port the app listens on. Keep it on loopback and put a reverse proxy in front.
PORT=3000

# URL path the library is served under. "/Library" -> example.com/Library
# Use "/" to serve it at the domain root.
BASE_PATH=/Library

# Full public URL of your site, no trailing slash. Used to build links in emails.
PUBLIC_URL=https://example.com

# Where the "Home" button goes (defaults to PUBLIC_URL).
HOME_URL=https://example.com

# --- Branding ---
LIBRARY_NAME=Lending Library
# Optional: shown under the title and in the footer. Leave blank to omit.
LIBRARY_LOCATION=

# Genres and statuses are edited from the admin panel (Categories & statuses) and saved
# to data/settings.json. These two variables only SEED the initial lists the first time
# the app runs, before you've saved anything from the panel — after that, settings.json
# wins and these are ignored. Leave them blank to start from the built-in defaults.
#
# Genres — comma-separated. Default: Fiction, Non-Fiction, Mystery, History, Science,
# Reference, Theology. The first entry is the fallback for a book with an unknown genre.
# Example: GENRES=Fiction,History,Poetry,Children,Reference
GENRES=

# Extra statuses beyond the four built-in workflow ones (Available, Reserved, On Loan,
# Reference Only, which are always present). "Out of circulation" labels — a book in one
# can't be reserved. Default: Unavailable.
# Example: STATUSES=Unavailable,Lost,Damaged,On Order,Withdrawn
STATUSES=

# --- Admin login ---
ADMIN_USER=admin
# bcrypt hash - never the plain password.  npm run set-password
ADMIN_PASSWORD_HASH=

# --- Sessions ---
# Long random string.  npm run gen-secret
SESSION_SECRET=
# Number of reverse proxies in front of the app (nginx/Caddy = 1, none = 0).
# Required for correct client IPs in rate limiting and the auth log.
TRUST_PROXY=1
# true when served over HTTPS. Set false ONLY for local http testing.
COOKIE_SECURE=true

# --- Email (optional) ---
# Leave SMTP_* blank to run without email: verification and reset links are
# written to logs/mail.log instead, and the admin panel shows them on screen.
#
# Proton Mail (SMTP submission token):
#   SMTP_HOST=smtp.protonmail.ch
#   SMTP_PORT=587
#   SMTP_USER=library@example.com     (must match the token's address)
#   SMTP_PASS=<token>
#
# Brevo / Sendinblue:
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=<your brevo login>
#   SMTP_PASS=<your brevo SMTP key>
#
# Gmail (app password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=library@example.com
MAIL_FROM_NAME=Lending Library
