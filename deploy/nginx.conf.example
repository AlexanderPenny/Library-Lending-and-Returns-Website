# Add inside the existing `server { }` block for your domain.
# The app owns the whole BASE_PATH, including /Library/admin and /Library/api/*.

location /Library {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;

    # Real client IP — required for rate limiting and fail2ban to work.
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    client_max_body_size 2m;
}

# Optional extra rate limit on login, at the nginx layer.
# In the http { } block:
#   limit_req_zone $binary_remote_addr zone=liblogin:10m rate=10r/m;
# Then place this ABOVE the block above:
# location = /Library/api/login {
#     limit_req zone=liblogin burst=5 nodelay;
#     proxy_pass http://127.0.0.1:3000;
#     proxy_set_header Host              $host;
#     proxy_set_header X-Real-IP         $remote_addr;
#     proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
#     proxy_set_header X-Forwarded-Proto $scheme;
# }
